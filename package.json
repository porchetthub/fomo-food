"use client";

import { motion } from "framer-motion";
import { Heart, MessageCircle, Share2, MapPin, Clock, Navigation } from "lucide-react";
import { Truck } from "@/data/vendors";
import { LivePill } from "@/components/ui/LivePill";
import { Badge } from "@/components/ui/Badge";
import Link from "next/link";
import { useState } from "react";
import { cn } from "@/lib/utils";

interface TruckCardProps {
  truck: Truck;
  index?: number;
  featured?: boolean;
}

export function TruckCard({ truck, index = 0, featured = false }: TruckCardProps) {
  const [liked, setLiked] = useState(false);
  const [imageIndex, setImageIndex] = useState(0);

  if (featured) {
    return (
      <motion.div
        initial={{ opacity: 0, scale: 0.95 }}
        animate={{ opacity: 1, scale: 1 }}
        transition={{ delay: index * 0.1 }}
        className="flex-shrink-0 w-[280px]"
      >
        <Link href={`/vendor/${truck.slug}`}>
          <div className="relative rounded-2xl overflow-hidden bg-pork-dark">
            <div className="aspect-[4/5] relative">
              <img
                src={truck.images[0]}
                alt={truck.name}
                className="w-full h-full object-cover"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
              <div className="absolute top-3 left-3 flex gap-2">
                {truck.isLive && <LivePill size="sm" />}
                <Badge variant="gold">{truck.zone}</Badge>
              </div>
              <div className="absolute bottom-0 left-0 right-0 p-4">
                <h3 className="text-white font-bold text-lg">{truck.name}</h3>
                <p className="text-white/70 text-xs mt-1">{truck.tagline}</p>
                <div className="flex items-center gap-3 mt-2">
                  <span className="text-amber-400 text-xs font-bold">★ {truck.rating}</span>
                  <span className="text-white/40 text-[10px]">{truck.reviewCount} recensioni</span>
                </div>
                <div className="flex gap-2 mt-3">
                  {truck.badges.slice(0, 2).map((b) => (
                    <Badge key={b} variant="gold">{b}</Badge>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </Link>
      </motion.div>
    );
  }

  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ delay: index * 0.08 }}
      className="bg-white rounded-2xl overflow-hidden shadow-sm border border-stone-100"
    >
      <div className="relative aspect-square">
        <img
          src={truck.images[imageIndex]}
          alt={truck.name}
          className="w-full h-full object-cover"
        />
        <div className="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent" />
        <div className="absolute top-3 left-3 right-3 flex items-center justify-between">
          <div className="flex items-center gap-2">
            {truck.isLive && <LivePill size="sm" />}
            <Badge variant="gold">{truck.zone}</Badge>
          </div>
          <button
            onClick={() => setLiked(!liked)}
            className="p-2 rounded-full bg-black/30 backdrop-blur-md"
          >
            <Heart className={cn("w-4 h-4", liked ? "fill-red-500 text-red-500" : "text-white")} />
          </button>
        </div>
        <div className="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1">
          {truck.images.map((_, i) => (
            <button
              key={i}
              onClick={() => setImageIndex(i)}
              className={cn(
                "w-1.5 h-1.5 rounded-full transition-all",
                i === imageIndex ? "bg-white w-4" : "bg-white/50"
              )}
            />
          ))}
        </div>
      </div>
      <div className="p-3.5">
        <div className="flex items-start justify-between">
          <div>
            <Link href={`/vendor/${truck.slug}`}>
              <h3 className="font-bold text-sm">{truck.name}</h3>
            </Link>
            <p className="text-[11px] text-muted-foreground mt-0.5">{truck.tagline}</p>
          </div>
          <div className="flex items-center gap-0.5">
            <span className="text-amber-500 text-xs">★</span>
            <span className="text-xs font-bold">{truck.rating}</span>
          </div>
        </div>
        <div className="flex items-center gap-3 mt-2 text-[10px] text-muted-foreground">
          <span className="flex items-center gap-1">
            <Clock className="w-3 h-3" />
            {truck.schedule.hours}
          </span>
          <span className="flex items-center gap-1">
            <MapPin className="w-3 h-3" />
            {truck.zone}
          </span>
        </div>
        <div className="flex flex-wrap gap-1 mt-2.5">
          {truck.badges.map((b) => (
            <Badge key={b} variant="gold">{b}</Badge>
          ))}
        </div>
        <div className="flex items-center justify-between mt-3 pt-3 border-t border-stone-100">
          <div className="flex items-center gap-4">
            <button
              onClick={() => setLiked(!liked)}
              className="flex items-center gap-1 text-[11px] text-muted-foreground"
            >
              <Heart className={cn("w-4 h-4", liked && "fill-red-500 text-red-500")} />
              {liked ? truck.reviewCount + 1 : truck.reviewCount}
            </button>
            <Link href={`/vendor/${truck.slug}`} className="flex items-center gap-1 text-[11px] text-muted-foreground">
              <MessageCircle className="w-4 h-4" />
              {truck.comments.length}
            </Link>
            <button
              onClick={() => {
                if (navigator.share) {
                  navigator.share({ title: truck.name, text: truck.tagline, url: window.location.href });
                }
              }}
              className="flex items-center gap-1 text-[11px] text-muted-foreground"
            >
              <Share2 className="w-4 h-4" />
              Condividi
            </button>
          </div>
          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${truck.coordinates.lat},${truck.coordinates.lng}`}
            target="_blank"
            rel="noopener noreferrer"
            className="p-2 rounded-full bg-pork-gold/10 text-pork-gold"
          >
            <Navigation className="w-3.5 h-3.5" />
          </a>
        </div>
      </div>
    </motion.div>
  );
}
